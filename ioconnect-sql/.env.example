# ==========================================================
# .env.example — ioconnect-sql adapter identity + build config
#
#   cp .env.example .env   &&   edit APP_NAME / VITE_* as needed
#
# TWO-FILE MODEL:
#   .env          — identity + build config (this file). Sourced by install.sh.
#   env/.env.api  — runtime config (PORT, METRICS_PORT, absolute paths),
#                   generated ONLY by install.sh. Never hand-edit.
# ==========================================================

# Unique slug for this deployment. Names the systemd service, nginx route
# (/apps/<APP_NAME>/), Kafka client id, and app_manifest.json appName.
APP_NAME=ioconnect-sql

# ----------------------------------------------------------
# FRONTEND / CONFIGURATOR BUILD
# ----------------------------------------------------------
VITE_BASE_PATH=/apps/ioconnect-sql/
VITE_STORAGE_KEY_PREFIX=ioconnect-sql
# Maps to configs/sql/schema.json in the configurator repo.
VITE_CONFIG_PROFILE=sql
VITE_APP_NAME=SQL Configurator
VITE_CSV_TAB_LABEL=Tags
VITE_MONITOR_TAB_LABEL=Live Values

# Dev-only (npm run dev / Vite proxy)
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:6768

# ----------------------------------------------------------
# BACKEND RUNTIME (manual-run only; install.sh overrides these)
# ----------------------------------------------------------
# Where config.csv + sys_parameters.json live.
FILES_BASE_DIR=./data
# Where start.sh / stop.sh / etc. live.
SCRIPTS_DIR=./scripts

# Kafka / Redpanda client identity.
KAFKA_CLIENT_ID=ioconnect-sql
KAFKA_GROUP_ID=ioconnect-sql-monitor

# ----------------------------------------------------------
# NOT IN THIS FILE (set by install.sh into env/.env.api):
#   PORT, METRICS_PORT   — dynamically allocated free ports
#   SERVICE_NAME         — derived from APP_NAME
#   REDPANDA_KAFKA_*     — injected by the IoConnect platform
# ----------------------------------------------------------
