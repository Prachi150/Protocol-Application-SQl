[Unit]
# Configurator UI + API on port 6767. Placeholders substituted by install-services.sh.
Description=IoConnect SQL Configurator (UI + API on port 6767)
After=network.target mariadb.service
Wants=mariadb.service

[Service]
Type=simple
User=@@USER@@
WorkingDirectory=@@CFG_DIR@@/server
EnvironmentFile=@@CFG_DIR@@/server/.env
ExecStart=@@NODE@@ dist/index.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
