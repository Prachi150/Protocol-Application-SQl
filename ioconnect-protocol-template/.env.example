# ==========================================================
# .env.example — Protocol Adapter Configuration Template
#
# ⚠  This file is NOT automatically loaded by Vite, dotenv, or any script.
#    It is a reference template only.
#
# USAGE:
#   IoConnect / Jenkins : .env is auto-generated by the pipeline — do not edit manually
#   All other modes     : cp .env.example .env  &&  nano .env
#                         (set APP_NAME and VITE_BASE_PATH at minimum)
#   Frontend dev (npm run dev): also cp .env configurator/.env
#
# TWO-FILE MODEL:
#   .env          — identity + build config (this file).
#                   Governs APP_NAME, VITE_* build-time vars, Kafka identity.
#                   Sourced by install.sh and build scripts; included in the release zip.
#   env/.env.api  — runtime config, generated ONLY by install.sh.
#                   Governs PORT, METRICS_PORT, absolute file paths, LOG_DIR.
#                   Loaded by systemd EnvironmentFile= for both Python and Node services.
#                   Never hand-edit after install — re-run install.sh to regenerate.
# ==========================================================

# ----------------------------------------------------------
# IDENTITY  —  required in ALL deployment modes
# ----------------------------------------------------------

# Unique slug for this deployment instance.
# Names systemd services, nginx routes (/apps/<APP_NAME>/), and Kafka identifiers.
# Must be URL-safe: lowercase letters, digits, hyphens only.
APP_NAME=my-myproto-app  # REPLACE: e.g. my-opcua-app, my-modbus-line1

# ----------------------------------------------------------
# FRONTEND BUILD  —  baked into the compiled JS at `npm run build`
# ⚠ Changing these after a build has NO effect without rebuilding the frontend.
# ----------------------------------------------------------

# URL base path where the React app is served.
# Must match the nginx location block install.sh creates.
# Set to '/' for a root-mounted standalone deployment.
VITE_BASE_PATH=/apps/my-myproto-app/  # REPLACE: match APP_NAME above

# localStorage key namespace. Prevents collisions when multiple instances share a domain.
VITE_STORAGE_KEY_PREFIX=my-myproto-app  # REPLACE: match APP_NAME above

# Schema/profile selector — the key that maps to a schema.json in the configurator.
# Existing values: opcua | modbus | s7
# REPLACE: register your profile in the configurator's schema system.
VITE_CONFIG_PROFILE=myproto  # REPLACE: e.g. opcua, modbus, s7

# Optional UI labels (have working defaults if omitted)
VITE_APP_NAME=MyProto Configurator  # REPLACE: human-readable name, e.g. "OPC UA Configurator"
VITE_CSV_TAB_LABEL=Tags
VITE_MONITOR_TAB_LABEL=Live Values

# ----------------------------------------------------------
# FRONTEND BUILD — DEV ONLY  (npm run dev / Vite proxy)
# NOT used in production builds — the API path is derived dynamically
# from window.location by src/lib/path.ts at runtime.
# ----------------------------------------------------------
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:3001

# ----------------------------------------------------------
# BACKEND RUNTIME  —  meaningful ONLY in Mode 4 (pure manual run).
# When install.sh runs (Modes 1–3), it overrides both values with
# absolute paths in env/.env.api and these entries are ignored.
# ----------------------------------------------------------

# Where config.csv and sys_parameters.json live.
# install.sh overrides this to: ${LSG_APP_DATA}/${APP_NAME}
# The protocol app also falls back to its own parent directory if this var is unset.
FILES_BASE_DIR=./data

# Where start.sh / stop.sh / etc. live.
# install.sh overrides this to the absolute scripts/ path inside the package.
SCRIPTS_DIR=./scripts

# Kafka / Redpanda client identity (install.sh passes these through into env/.env.api)
KAFKA_CLIENT_ID=my-myproto-app-configurator  # REPLACE: match APP_NAME — Producer client ID visible in broker logs
KAFKA_GROUP_ID=my-myproto-app-monitor        # REPLACE: match APP_NAME — Consumer group used by the live-monitor tab

# ----------------------------------------------------------
# VARIABLES NOT IN THIS FILE
#
# PORT, METRICS_PORT
#     Dynamically allocated by install.sh (first two free ports above 5000).
#     Written to env/.env.api only — never set manually.
#
# SERVICE_NAME
#     Derived automatically from APP_NAME by install.sh and all scripts.
#     Written to env/.env.api for Python/Node runtime use — not a user-facing variable.
#
# REDPANDA_KAFKA_ADDRESS, REDPANDA_KAFKA_SECURITY_PROTOCOL, REDPANDA_KAFKA_SASL_MECHANISM
#     Injected by the IoConnect platform via /etc/environment.
#     For --no-ioconnect: configure the broker address in data/sys_parameters.json
#     (posting[].broker) or export REDPANDA_KAFKA_ADDRESS manually before starting.
#
# REDPANDA_KAFKA_SASL_USERNAME, REDPANDA_KAFKA_SASL_PASSWORD
#     Only needed for authenticated broker setups. Not set by the platform by default.
#     Export manually if your Redpanda instance requires SASL credentials.
#
# LSG_APPS_HOME, LSG_APP_DATA, NGINX_SNIPPET_DIR
#     IoConnect platform paths from /etc/environment.
#     For --no-ioconnect: install.sh will interactively prompt for these.
# ----------------------------------------------------------
