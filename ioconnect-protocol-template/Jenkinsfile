// ==============================================================================
// Jenkinsfile — IoConnect Protocol Adapter Build Pipeline (TEMPLATE)
//
// [SECTION: CUSTOMIZATION POINTS]
// This pipeline is structurally identical for all protocol adapters.
// Search for "REPLACE" to find all per-protocol customization sites (3 total):
//   1. APP_NAME defaultValue   — the deployment instance slug
//   2. VITE_CONFIG_PROFILE     — profile key for the configurator schema system
//   3. VITE_APP_NAME           — human-readable title in the browser tab
//
// [SECTION: WHAT THIS PIPELINE DOES]
// Stage 1: Generate .env with VITE_* vars (baked into JS at build time)
// Stage 2: Clone the shared configurator frontend from a separate repo
// Stage 3: Build the React frontend + Node.js backend (TypeScript → JS)
// Stage 4: Package everything into an architecture-specific .zip release artifact
//          The zip is what gets shipped to IoConnect devices and extracted there.
//          install.sh inside the zip then sets up systemd, nginx, venv, etc.
// ==============================================================================

pipeline {
    agent any

    parameters {
        // REPLACE: Change the defaultValue to a slug for your new protocol app.
        // Convention: lsg-<protocol>-<instance>, e.g. lsg-myproto-testing
        string(name: 'APP_NAME', defaultValue: 'lsg-myproto-testing', description: 'The unique app name for this deployment')

        string(name: 'BUILD_VERSION', defaultValue: '1.0.0', description: 'Semantic version for this release (e.g. 1.2.3)')
        string(name: 'CONFIGURATOR_REPO', defaultValue: 'git@github.com:Faclon-IoT-Team/ioconnect-protocol-configurator.git', description: 'SSH URL of the Configurator Repo')
        string(name: 'CONFIGURATOR_BRANCH', defaultValue: 'main', description: 'Branch to pull for the Configurator')
        credentials(name: 'GIT_SSH_CREDENTIAL_ID', description: 'SSH credential ID for GitHub repo access', credentialType: 'com.cloudbees.jenkins.plugins.sshcredentials.impl.BasicSSHUserPrivateKey', required: true)
        choice(name: 'TARGET_ARCH', choices: ['linux-x64', 'linux-arm64', 'windows-x64'], description: 'Target Architecture for the final package')
    }

    environment {
        APP_NAME = "${params.APP_NAME}"
        BUILD_VERSION = "${params.BUILD_VERSION}"
        ZIP_NAME = "${params.APP_NAME}-release-${params.TARGET_ARCH}-build-${BUILD_NUMBER}.zip"
    }

    stages {
        stage('1. Prepare Workspace & Config') {
            steps {
                sh 'rm -rf configurator .env data'
                sh 'mkdir -p data && cp sample-configs/* data/ 2>/dev/null || true'

                // Generate .env BEFORE building the frontend.
                // Vite bakes VITE_* variables into the compiled JS at build time —
                // changing them after a build has no effect without rebuilding.
                sh '''
                    cat <<EOF > .env
# Generated by Jenkins Build #${BUILD_NUMBER}
APP_NAME="${APP_NAME}"
BUILD_VERSION="${BUILD_VERSION}"
FILES_BASE_DIR=./data
SCRIPTS_DIR=./scripts
KAFKA_CLIENT_ID="${APP_NAME}-configurator"
KAFKA_GROUP_ID="${APP_NAME}-monitor"
VITE_BASE_PATH="/apps/${APP_NAME}/"
VITE_CONFIG_PROFILE=myproto
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:3001
VITE_APP_NAME="MyProto Configurator"
VITE_CSV_TAB_LABEL="Tags"
VITE_MONITOR_TAB_LABEL="Live Values"
VITE_STORAGE_KEY_PREFIX="${APP_NAME}"
EOF
                '''
                // ^^^ REPLACE the two lines above:
                //   VITE_CONFIG_PROFILE=myproto       — profile key registered in the configurator schema system
                //                                        (existing values: opcua | modbus | s7)
                //   VITE_APP_NAME="MyProto Configurator" — human-readable tab title shown in the browser
            }
        }

        // NOTE: Stages 2–4 and the post{} block are identical for all protocol adapters.
        // Do not modify them unless the configurator repo structure changes.
        // GENERIC-APP NOTE: Stages 2 and 3 are only needed for apps using the shared
        // opc-ua-configurator UI. If your app has its own UI repo, replace Stage 2
        // with a clone of that repo. If your app has no UI, remove Stages 2 and 3
        // entirely and remove 'configurator/' from the zip command in Stage 4.

        stage('2. Pull Configurator Repository') {
            steps {
                sshagent(credentials: [params.GIT_SSH_CREDENTIAL_ID]) {
                    sh """
                        git clone \\
                            --branch ${params.CONFIGURATOR_BRANCH} \\
                            ${params.CONFIGURATOR_REPO} \\
                            configurator
                    """
                }
                // Remove .git from the cloned repo so it is not included in the zip.
                // The configurator is source code only — its git history is irrelevant
                // to the target device.
                sh 'rm -rf configurator/.git'
            }
        }

        stage('3. Build Configurator Assets') {
            steps {
                dir('configurator') {
                    sh '''
                        set -a
                        . ../.env
                        set +a
                        npm ci
                        npm run build
                        rm -rf node_modules
                    '''
                    // NOTE: .env is sourced here so Vite picks up VITE_* vars.
                }
                dir('configurator/server') {
                    sh 'npm ci'
                    sh 'npm run build'
                    // Reinstall with only production dependencies — dev tools not needed at runtime.
                    sh 'npm ci --omit=dev'
                }
            }
        }

        stage('4. Prepare Release Artifact') {
            steps {
                // Remove fallback scripts in the server folder (only needed during development).
                sh 'rm -rf configurator/server/scripts'

                // Create the final architecture-specific zip file.
                // NOTE: app_manifest.json is NOT included — it is generated by install.sh
                // at installation time with absolute paths specific to the target device.
                sh """
                    zip -r ${ZIP_NAME} \\
                        .env \\
                        requirements.txt \\
                        src/ \\
                        scripts/ \\
                        data/ \\
                        configurator/ \\
                        packages/
                """
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: "${ZIP_NAME}", fingerprint: true
            echo "Successfully packaged ${ZIP_NAME} for IOConnect ecosystem."
        }
        failure {
            echo "Pipeline failed. Please check the logs."
        }
    }
}
