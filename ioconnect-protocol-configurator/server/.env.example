PORT=3001
SERVICE_NAME=my-opcua-service
FILES_BASE_DIR=./data
SCRIPTS_DIR=./scripts

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CLIENT_ID=lsg-opcua-configurator
KAFKA_GROUP_ID=lsg-opcua-monitor

# Auto Onboard — Master MQTT broker (sourced from /etc/environmet and /run/lsg-app/secrets.env  on device)
MASTER_MQTT_HOST=hap.faclon.com
MASTER_MQTT_PORT=1883
MASTER_MQTT_USERNAME=fapr22
MASTER_MQTT_PASSWORD=applepie
# Set to "true" to use mqtts (TLS)
MASTER_MQTT_TLS=false

# Auto Onboard — orchestrator and protocol identity
# URL of the lsg-app orchestrator (used to fetch asset_id)
LSG_APP_URL=http://localhost:3001
# Full protocol app name as registered in lsg-app (e.g. ioconnect-opcua, ioconnect-modbus)
PROTOCOL_APP_NAME=ioconnect-opcua

# Auto Onboard — tuning
# Rows per MQTT batch message (default: 100)
ONBOARD_BATCH_SIZE=100
# Milliseconds to wait for a response before timing out per batch (default: 10000)
ONBOARD_TIMEOUT_MS=10000

