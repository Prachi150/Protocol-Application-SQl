# Public path for deployment (e.g., /apps/lsg-opcua/)
VITE_BASE_PATH=/apps/lsg-opcua/

# Configuration profile (e.g., opcua)
VITE_CONFIG_PROFILE=opcua

# Backend API base path (e.g., /api)
VITE_API_BASE=/api

# Backend API target URL (only used by Vite proxy during development)
VITE_API_TARGET=http://localhost:3001

# UI Customization
VITE_APP_NAME=OPC UA Configurator
VITE_CSV_TAB_LABEL=Tags
VITE_MONITOR_TAB_LABEL=Live Values

# Storage Keys (to avoid collisions when running multiple instances on one domain)
VITE_STORAGE_KEY_PREFIX=lsg-opcua
