{
  "profile": "fins",
  "label": "Omron FINS",
  "pollingEntryServerField": "protocol.server",
  "pollingEntryPortField": "protocol.port",

  "polling": {
    "sectionLabel": "FINS PLCs",
    "entryLabel": "FINS PLC",
    "sections": [
      {
        "key": "protocol",
        "label": "Protocol",
        "fields": [
          { "key": "protocol.type",   "label": "type",   "widget": "select", "default": "fins-tcp", "options": ["fins-tcp", "fins-udp"], "disableWhen": null },
          { "key": "protocol.server", "label": "server", "widget": "text",   "default": "",         "disableWhen": null },
          { "key": "protocol.port",   "label": "port",   "widget": "number", "default": 9600,       "disableWhen": null }
        ]
      },
      {
        "key": "protocol_node",
        "label": "FINS Node Addressing",
        "fields": [
          { "key": "protocol.dna", "label": "dna (dest network)",  "widget": "number", "default": 0, "disableWhen": null },
          { "key": "protocol.da1", "label": "da1 (dest node)",     "widget": "number", "default": 0, "disableWhen": null },
          { "key": "protocol.da2", "label": "da2 (dest unit)",     "widget": "number", "default": 0, "disableWhen": null },
          { "key": "protocol.sna", "label": "sna (src network)",   "widget": "number", "default": 0, "disableWhen": null },
          { "key": "protocol.sa1", "label": "sa1 (src node)",      "widget": "number", "default": 1, "disableWhen": null },
          { "key": "protocol.sa2", "label": "sa2 (src unit)",      "widget": "number", "default": 0, "disableWhen": null }
        ]
      },
      {
        "key": "__root__",
        "label": "Connection Settings",
        "fields": [
          { "key": "interpoll_delay",     "label": "interpoll_delay",     "widget": "number", "default": 10,       "disableWhen": null },
          { "key": "connect_retry_count", "label": "connect_retry_count", "widget": "number", "default": 3,        "disableWhen": null },
          { "key": "poll_retry_count",    "label": "poll_retry_count",    "widget": "number", "default": 3,        "disableWhen": null },
          { "key": "connect_retry_time",  "label": "connect_retry_time",  "widget": "number", "default": 5000,     "disableWhen": null },
          { "key": "connection_type",     "label": "connection_type",     "widget": "select", "default": "persist","options": ["persist", "nonpersist"], "disableWhen": null },
          { "key": "poll_timeout",        "label": "poll_timeout",        "widget": "number", "default": 1000,     "disableWhen": null },
          { "key": "connection_timeout",  "label": "connection_timeout",  "widget": "number", "default": 5000,     "disableWhen": null },
          { "key": "write_timeout",       "label": "write_timeout",       "widget": "number", "default": 2000,     "disableWhen": null }
        ]
      },
      {
        "key": "command_server",
        "label": "Write Command Server",
        "fields": [
          { "key": "command_server.enabled",        "label": "enabled",        "widget": "boolean", "default": false, "disableWhen": null },
          { "key": "command_server.type",           "label": "type",           "widget": "select",  "default": "http", "options": ["http", "mqtt"], "disableWhen": { "field": "command_server.enabled", "op": "eq", "value": false } },
          { "key": "command_server.port",           "label": "port",           "widget": "number",  "default": 8080,  "disableWhen": { "field": "command_server.enabled", "op": "eq", "value": false } },
          { "key": "command_server.path",           "label": "path (HTTP)",    "widget": "text",    "default": "/write", "disableWhen": { "field": "command_server.type", "op": "eq", "value": "mqtt" } },
          { "key": "command_server.topic",          "label": "topic (MQTT)",   "widget": "text",    "default": "commands/in", "disableWhen": { "field": "command_server.type", "op": "eq", "value": "http" } },
          { "key": "command_server.response_topic", "label": "response_topic", "widget": "text",    "default": "commands/out", "disableWhen": { "field": "command_server.type", "op": "eq", "value": "http" } },
          { "key": "command_server.host",           "label": "host (MQTT)",    "widget": "text",    "default": "localhost", "disableWhen": { "field": "command_server.type", "op": "eq", "value": "http" } },
          { "key": "command_server.target_port",    "label": "target_port",    "widget": "number",  "default": 1883, "disableWhen": { "field": "command_server.type", "op": "eq", "value": "http" } },
          { "key": "command_server.clientId",       "label": "clientId",       "widget": "text",    "default": "FINSWriter", "disableWhen": { "field": "command_server.enabled", "op": "eq", "value": false } }
        ]
      }
    ],
    "summary": {
      "titleTemplate": "FINS PLC #{index}",
      "subtitleField": "protocol.server",
      "badges": [
        { "label": "Type",       "field": "protocol.type",   "colorRules": [{ "value": "fins-tcp", "color": "primary" }, { "value": "*", "color": "muted" }] },
        { "label": "Connection", "field": "connection_type", "colorRules": [{ "value": "*", "color": "muted" }] },
        { "label": "Writes",     "field": "command_server.enabled", "booleanLabels": { "true": "Enabled", "false": "Off" }, "colorRules": [{ "value": "true", "color": "success" }, { "value": "*", "color": "muted" }] }
      ]
    }
  },

  "posting": {
    "types": [
      {
        "type": "redpanda",
        "label": "Redpanda",
        "pinToIndex0": true,
        "sections": [
          {
            "key": "__root__",
            "label": "Redpanda / Kafka Settings",
            "fields": [
              { "key": "bootstrap_servers", "label": "bootstrap_servers", "widget": "text",    "default": "localhost:9092", "disableWhen": null },
              { "key": "security_protocol", "label": "security_protocol", "widget": "select",  "default": "PLAINTEXT",     "options": ["PLAINTEXT", "SASL_PLAINTEXT", "SASL_SSL"], "disableWhen": null },
              { "key": "sasl_mechanism",    "label": "sasl_mechanism",    "widget": "select",  "default": "PLAIN",         "options": ["PLAIN", "SCRAM-SHA-256", "SCRAM-SHA-512"],  "disableWhen": { "field": "security_protocol", "op": "eq", "value": "PLAINTEXT" } },
              { "key": "sasl_username",     "label": "sasl_username",     "widget": "text",    "default": "",              "disableWhen": { "field": "security_protocol", "op": "eq", "value": "PLAINTEXT" } },
              { "key": "sasl_password",     "label": "sasl_password",     "widget": "text",    "default": "",              "disableWhen": { "field": "security_protocol", "op": "eq", "value": "PLAINTEXT" } },
              { "key": "client_id",         "label": "client_id",         "widget": "text",    "default": "fins-protocol", "disableWhen": null },
              { "key": "acks",              "label": "acks",              "widget": "select",  "default": "all",           "options": ["0", "1", "all"], "disableWhen": null },
              { "key": "compression_type",  "label": "compression_type",  "widget": "select",  "default": "lz4",           "options": ["none", "gzip", "snappy", "lz4", "zstd"], "disableWhen": null },
              { "key": "localbackup",       "label": "localbackup",       "widget": "boolean", "default": false,           "disableWhen": null },
              { "key": "backupfile",        "label": "backupfile",        "widget": "text",    "default": "",              "disableWhen": null },
              { "key": "blocking",          "label": "blocking",          "widget": "boolean", "default": false,           "disableWhen": null },
              { "key": "stringPosting",     "label": "stringPosting",     "widget": "boolean", "default": true,            "disableWhen": null }
            ]
          }
        ],
        "summary": {
          "titleTemplate": "REDPANDA #{index}",
          "subtitleField": "bootstrap_servers",
          "badges": [
            { "label": "Security",  "field": "security_protocol", "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "SASL",      "field": "sasl_mechanism",    "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Compress",  "field": "compression_type",  "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Backup",    "field": "localbackup",       "booleanLabels": { "true": "Yes", "false": "No" }, "colorRules": [{ "value": "true", "color": "success" }, { "value": "*", "color": "muted" }] }
          ]
        }
      },
      {
        "type": "mqtt",
        "label": "MQTT",
        "pinToIndex0": false,
        "sections": [
          {
            "key": "__root__",
            "label": "MQTT Settings",
            "fields": [
              { "key": "host",          "label": "host",          "widget": "text",    "default": "",    "disableWhen": null },
              { "key": "port",          "label": "port",          "widget": "number",  "default": 1883,  "disableWhen": null },
              { "key": "username",      "label": "username",      "widget": "text",    "default": "",    "disableWhen": null },
              { "key": "password",      "label": "password",      "widget": "text",    "default": "",    "disableWhen": null },
              { "key": "qos",           "label": "qos",           "widget": "number",  "default": 0,     "disableWhen": null },
              { "key": "keepalive",     "label": "keepalive",     "widget": "number",  "default": 60,    "disableWhen": null },
              { "key": "clientId",      "label": "clientId",      "widget": "text",    "default": "",    "disableWhen": null },
              { "key": "localbackup",   "label": "localbackup",   "widget": "boolean", "default": false, "disableWhen": null },
              { "key": "backupfile",    "label": "backupfile",    "widget": "text",    "default": "",    "disableWhen": null },
              { "key": "blocking",      "label": "blocking",      "widget": "boolean", "default": false, "disableWhen": null },
              { "key": "stringPosting", "label": "stringPosting", "widget": "boolean", "default": true,  "disableWhen": null }
            ]
          }
        ],
        "summary": {
          "titleTemplate": "MQTT #{index}",
          "subtitleField": "host",
          "subtitleSuffix": "port",
          "badges": [
            { "label": "QoS",       "field": "qos",         "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Keepalive", "field": "keepalive",   "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Backup",    "field": "localbackup", "booleanLabels": { "true": "Yes", "false": "No" }, "colorRules": [{ "value": "true", "color": "success" }, { "value": "*", "color": "muted" }] }
          ]
        }
      },
      {
        "type": "http",
        "label": "HTTP",
        "pinToIndex0": false,
        "sections": [
          {
            "key": "__root__",
            "label": "HTTP Settings",
            "fields": [
              { "key": "host",          "label": "host",          "widget": "text",    "default": "http://localhost", "disableWhen": null },
              { "key": "port",          "label": "port",          "widget": "number",  "default": 8001,              "disableWhen": null },
              { "key": "method",        "label": "method",        "widget": "text",    "default": "POST",            "disableWhen": null },
              { "key": "timeout",       "label": "timeout",       "widget": "number",  "default": 1000,              "disableWhen": null },
              { "key": "path",          "label": "path",          "widget": "text",    "default": "/",               "disableWhen": null },
              { "key": "localbackup",   "label": "localbackup",   "widget": "boolean", "default": false,             "disableWhen": null },
              { "key": "backupfile",    "label": "backupfile",    "widget": "text",    "default": "",                "disableWhen": null },
              { "key": "blocking",      "label": "blocking",      "widget": "boolean", "default": false,             "disableWhen": null },
              { "key": "stringPosting", "label": "stringPosting", "widget": "boolean", "default": true,              "disableWhen": null }
            ]
          }
        ],
        "summary": {
          "titleTemplate": "HTTP #{index}",
          "subtitleField": "host",
          "subtitleSuffix": "port",
          "badges": [
            { "label": "Method", "field": "method",      "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Path",   "field": "path",        "colorRules": [{ "value": "*", "color": "muted" }] },
            { "label": "Backup", "field": "localbackup", "booleanLabels": { "true": "Yes", "false": "No" }, "colorRules": [{ "value": "true", "color": "success" }, { "value": "*", "color": "muted" }] }
          ]
        }
      }
    ]
  },

  "csv": {
    "columns": [
      { "key": "device",        "label": "Device ID",       "widget": "text",          "width": null,    "monospace": false, "visibleWhen": null, "unsHidden": true },
      { "key": "tag",           "label": "Tag Name",        "widget": "text",          "width": null,    "monospace": false, "visibleWhen": null, "unsHidden": true },
      { "key": "area",          "label": "Memory Area",     "widget": "select",        "options": ["DM", "CIO", "WR", "HR", "AR", "EM"], "width": "80px",  "monospace": false, "visibleWhen": null, "includeInOnboard": true },
      { "key": "address",       "label": "Word Address",    "widget": "text",          "width": null,    "monospace": true,  "visibleWhen": null, "includeInOnboard": true },
      { "key": "bit",           "label": "Bit (0-15)",      "widget": "text",          "width": "70px",  "monospace": true,  "visibleWhen": null, "includeInOnboard": true },
      { "key": "len",           "label": "Word Length",     "widget": "text",          "width": "80px",  "monospace": true,  "visibleWhen": null, "includeInOnboard": true },
      { "key": "datatype",      "label": "Data Type",       "widget": "select",        "options": ["bool", "int", "uint", "dint", "udint", "real", "lreal"], "width": "90px", "monospace": false, "visibleWhen": null },
      { "key": "byteorder",     "label": "Byte Order",      "widget": "select",        "options": ["ABCD", "CDAB", "BADC", "DCBA"], "width": "90px", "monospace": false, "visibleWhen": null },
      { "key": "resolution",    "label": "Resolution",      "widget": "text",          "width": "90px",  "monospace": false, "visibleWhen": null },
      { "key": "server",        "label": "PLC IP",          "widget": "server-select", "width": null,    "monospace": false, "visibleWhen": null, "includeInOnboard": true },
      { "key": "port",          "label": "Port",            "widget": "port-select",   "width": "80px",  "monospace": false, "visibleWhen": null, "includeInOnboard": true },
      { "key": "lograte",       "label": "Poll Rate (ms)",  "widget": "text",          "width": "105px", "monospace": false, "visibleWhen": null },
      { "key": "auto_onboarded","label": "Onboarded",       "widget": "text",          "width": "100px", "monospace": false, "visibleWhen": null, "readOnly": true, "default": "false" }
    ]
  }
}
