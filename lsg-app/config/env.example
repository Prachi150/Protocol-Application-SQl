# =============================================================================
# LSG-App — Configuration Template
#
# HOW THIS WORKS IN PRODUCTION:
#   The install.sh script creates two separate files:
#
#   /etc/lsg-app/config.env        ← safe variables (copy of this file)
#   /etc/lsg-app/secrets.env.age   ← age-encrypted secrets
#
#   On each boot, systemd decrypts secrets.env.age into /run/lsg-app/secrets.env
#   (RAM-only tmpfs — never written to disk). The Node.js process reads both
#   files via systemd EnvironmentFile directives.
#
# DEVELOPMENT:
#   Copy this file to .env in the repo root and fill in the secret values.
#   The .env file is in .gitignore and should never be committed.
#
#     cp config/env.example .env
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=*

# ── Core ──────────────────────────────────────────────────────────────────────
MAX_PAYLOAD_SIZE=10mb

# ── Master MQTT (IoAdmin platform link) ──────────────────────────────────────
MASTER_MQTT_HOST=localhost
MASTER_MQTT_PORT=1883

# ── Redpanda ──────────────────────────────────────────────────────────────────
REDPANDA_BROKER_PORT=9092

# ── Heartbeat ─────────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=30000

# ── IoAdmin ───────────────────────────────────────────────────────────────────
IOADMIN_URL=

# ── Secrets ───────────────────────────────────────────────────────────────────
# In production these are stored in secrets.env.age (age-encrypted, device key).
# The first-run setup wizard collects and writes them — do not set by hand in prod.
# In development, set them manually in your local .env file.
SETUP_COMPLETE=false
JWT_SECRET=
JWT_EXPIRES_IN=24h
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
INTERNAL_API_KEY=
GITHUB_TOKEN=
MASTER_MQTT_USERNAME=
MASTER_MQTT_PASSWORD=
